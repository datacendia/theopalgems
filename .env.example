VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key

# ─── Netlify Function env vars (set these in the Netlify dashboard, NOT here) ───
# These are read server-side by netlify/functions/*. Never expose them to the client.

# Inventory app sync — pushes warranty registrants into Andrew's "customers" table.
# Leave unset to disable the sync entirely (warranty registration still works).
# The service key is a master key to that database — store it ONLY in Netlify env vars.
INVENTORY_SUPABASE_URL=https://your-inventory-project.supabase.co
INVENTORY_SUPABASE_SERVICE_KEY=the-sb_secret_-key-from-the-inventory-project
INVENTORY_CUSTOMERS_TABLE=customers
